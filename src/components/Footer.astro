---
// src/components/Footer.astro
---
<footer class="bg-gray-950 text-gray-400 py-12 border-t border-gray-900">
  <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6">
    <p class="text-sm">© {new Date().getFullYear()} VerdeHome. Alle rechten voorbehouden.</p>
    
    <div class="flex items-center gap-2 bg-gray-900 px-4 py-2 rounded-full border border-gray-800 cursor-default hover:border-gray-700 transition-colors" title="Engineered for maximum performance and conversion">
      <div class="w-2 h-2 rounded-full bg-green-500 animate-[pulse_2s_ease-in-out_infinite]"></div>
      <span class="text-xs font-mono font-semibold text-gray-300 tracking-wider">FYXO 100/100 PERFORMANCE</span>
    </div>
  </div>
</footer>
